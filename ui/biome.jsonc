{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!dist",
      "!storybook-static"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "complexity": {
        "noExcessiveLinesPerFunction": {
          "level": "error",
          "options": {
            "maxLines": 100,
            "skipBlankLines": true,
            "skipIifes": true
          }
        }
      },
      "nursery": {
        "noExcessiveLinesPerFile": {
          "level": "error",
          "options": {
            "maxLines": 450,
            "skipBlankLines": true
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/api/generated/**"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveLinesPerFunction": "off"
          },
          "nursery": {
            "noExcessiveLinesPerFile": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/**/*.test.ts",
        "src/**/*.test.tsx",
        "src/**/*.test.mjs",
        "integration/**/*.test.ts",
        "integration/**/*.test.tsx",
        "integration/**/*.test.mjs",
        "src/**/*.stories.tsx"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveLinesPerFunction": {
              "level": "error",
              "options": {
                "maxLines": 160,
                "skipBlankLines": true,
                "skipIifes": true
              }
            }
          },
          "nursery": {
            "noExcessiveLinesPerFile": {
              "level": "error",
              "options": {
                "maxLines": 900,
                "skipBlankLines": true
              }
            }
          }
        }
      }
    }
  ]
}
