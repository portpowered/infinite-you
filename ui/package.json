{
  "name": "agent-factory-dashboard-ui",
  "private": true,
  "version": "0.0.0",
  "packageManager": "bun@1.3.12",
  "type": "module",
  "scripts": {
    "build-storybook": "storybook build --loglevel warn",
    "build": "tsc -b && vite build && bun scripts/normalize-dist-output.mjs",
    "capture:heap-snapshot": "node scripts/capture-heap-snapshot.mjs",
    "check:work-outcome-memory": "bun scripts/check-work-outcome-memory.ts",
    "check": "biome check .",
    "dev": "vite",
    "format": "biome format --write .",
    "generate-api": "openapi-typescript ../api/openapi.yaml -o src/api/generated/openapi.ts",
    "lint": "biome lint .",
    "loadtest:agent-fails-memory": "bun scripts/loadtest-agent-fails-memory.ts",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "replay:coverage": "bun scripts/write-replay-coverage-report.ts",
    "replay:coverage:check": "bun scripts/write-replay-coverage-report.ts --check",
    "storybook": "storybook dev -p 6007",
    "storybook:serve-static": "http-server storybook-static -p 6008 -a 127.0.0.1 -s",
    "storybook:wait-for-index": "wait-on --timeout 30000 http://127.0.0.1:6008/index.json",
    "storybook:test-runner:ci": "vitest run --config vitest.storybook.config.ts --project=storybook",
    "test:coverage": "vitest run --coverage --exclude integration/event-stream-replay.integration.test.mjs",
    "test:integration": "vitest run integration/event-stream-replay.integration.test.mjs",
    "test:unit": "vitest run --exclude integration/event-stream-replay.integration.test.mjs",
    "test": "bun run test:unit && bun run test:integration",
    "test-storybook": "bun scripts/run-storybook-ci.mjs",
    "tsc": "tsc -b --noEmit --pretty false"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tanstack/react-query": "^5.90.2",
    "@xyflow/react": "^12.10.2",
    "d3": "^7.9.0",
    "elkjs": "^0.11.1",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-grid-layout": "^2.2.3",
    "react-resizable-panels": "^4.10.0",
    "recharts": "^3.8.1",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/d3": "^7.4.3",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react-swc": "^4.1.0",
    "@vitest/browser": "4.1.3",
    "@vitest/browser-playwright": "4.1.3",
    "@vitest/coverage-v8": "4.1.3",
    "http-server": "^14.1.1",
    "jsdom": "^27.0.1",
    "openapi-typescript": "^7.10.1",
    "playwright": "^1.58.2",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^7.1.7",
    "vitest": "4.1.3",
    "wait-on": "^9.0.4"
  }
}
