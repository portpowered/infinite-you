{
  "workTypes": [
    {
      "name": "task",
      "states": [
        {
          "name": "init",
          "type": "INITIAL"
        },
        {
          "name": "in-review",
          "type": "IN_REVIEW"
        },
        {
          "name": "complete",
          "type": "TERMINAL"
        },
        {
          "name": "failed",
          "type": "FAILED"
        }
      ]
    },
    {
      "name": "idea",
      "states": [
        {
          "name": "init",
          "type": "INITIAL"
        },
        {
          "name": "complete",
          "type": "TERMINAL"
        },
        {
          "name": "failed",
          "type": "FAILED"
        }
      ]
    },
    {
      "name": "plan",
      "states": [
        {
          "name": "init",
          "type": "INITIAL"
        },
        {
          "name": "complete",
          "type": "TERMINAL"
        },
        {
          "name": "failed",
          "type": "FAILED"
        }
      ]
    }
  ],
  "workers": [
    {
      "name": "processor"
    },
    {
      "name": "workspace-setup"
    }
  ],
  "workstations": [
    {
      "inputs": [
        {
          "state": "init",
          "workType": "idea"
        }
      ],
      "name": "plan",
      "onFailure": {
        "state": "failed",
        "workType": "idea"
      },
      "onRejection": {
        "state": "failed",
        "workType": "idea"
      },
      "outputs": [
        {
          "state": "complete",
          "workType": "idea"
        },
        {
          "state": "init",
          "workType": "plan"
        }
      ],
      "worker": "processor"
    },
    {
      "inputs": [
        {
          "state": "init",
          "workType": "plan"
        }
      ],
      "name": "setup-workspace",
      "onFailure": {
        "state": "failed",
        "workType": "plan"
      },
      "outputs": [
        {
          "state": "complete",
          "workType": "plan"
        },
        {
          "state": "init",
          "workType": "task"
        }
      ],
      "worker": "workspace-setup"
    },
    {
      "inputs": [
        {
          "state": "init",
          "workType": "task"
        }
      ],
      "kind": "repeater",
      "name": "process",
      "onFailure": {
        "state": "failed",
        "workType": "task"
      },
      "onRejection": {
        "state": "init",
        "workType": "task"
      },
      "outputs": [
        {
          "state": "in-review",
          "workType": "task"
        }
      ],
      "worker": "processor",
      "worktree": "{{ (index .Inputs 0).Name }}"
    },
    {
      "inputs": [
        {
          "state": "in-review",
          "workType": "task"
        }
      ],
      "name": "review",
      "onFailure": {
        "state": "failed",
        "workType": "task"
      },
      "onRejection": {
        "state": "init",
        "workType": "task"
      },
      "outputs": [
        {
          "state": "complete",
          "workType": "task"
        }
      ],
      "worker": "processor",
      "worktree": "{{ (index .Inputs 0).Name }}"
    },
    {
      "guards": [
        {
          "maxVisits": 50,
          "type": "visit_count",
          "workstation": "process"
        }
      ],
      "inputs": [
        {
          "state": "init",
          "workType": "task"
        }
      ],
      "name": "executor-loop-breaker",
      "outputs": [
        {
          "state": "failed",
          "workType": "task"
        }
      ],
      "type": "LOGICAL_MOVE",
      "worker": ""
    }
  ]
}
