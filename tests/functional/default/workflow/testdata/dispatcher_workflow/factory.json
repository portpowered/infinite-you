{
  "workTypes": [
    {
      "name": "idea",
      "states": [
        {
          "name": "init",
          "type": "INITIAL"
        },
        {
          "name": "failed",
          "type": "FAILED"
        }
      ]
    },
    {
      "name": "prd",
      "states": [
        {
          "name": "init",
          "type": "INITIAL"
        },
        {
          "name": "in-review",
          "type": "PROCESSING"
        },
        {
          "name": "complete",
          "type": "TERMINAL"
        },
        {
          "name": "failed",
          "type": "FAILED"
        }
      ]
    }
  ],
  "workers": [
    {
      "name": "planner"
    },
    {
      "name": "executor"
    },
    {
      "name": "reviewer"
    }
  ],
  "workstations": [
    {
      "inputs": [
        {
          "state": "init",
          "workType": "idea"
        }
      ],
      "name": "plan",
      "onFailure": {
        "state": "failed",
        "workType": "idea"
      },
      "outputs": [
        {
          "state": "init",
          "workType": "prd"
        }
      ],
      "worker": "planner"
    },
    {
      "inputs": [
        {
          "state": "init",
          "workType": "prd"
        }
      ],
      "name": "execute",
      "onFailure": {
        "state": "failed",
        "workType": "prd"
      },
      "outputs": [
        {
          "state": "in-review",
          "workType": "prd"
        }
      ],
      "worker": "executor",
      "workingDirectory": "/workspaces/{{ index (index .Inputs 0).Tags \"work_item_id\" }}"
    },
    {
      "inputs": [
        {
          "state": "in-review",
          "workType": "prd"
        }
      ],
      "name": "review",
      "onFailure": {
        "state": "failed",
        "workType": "prd"
      },
      "onRejection": {
        "state": "init",
        "workType": "prd"
      },
      "outputs": [
        {
          "state": "complete",
          "workType": "prd"
        }
      ],
      "worker": "reviewer"
    },
    {
      "guards": [
        {
          "maxVisits": 3,
          "type": "visit_count",
          "workstation": "review"
        }
      ],
      "inputs": [
        {
          "state": "init",
          "workType": "prd"
        }
      ],
      "name": "review-exhaustion",
      "outputs": [
        {
          "state": "failed",
          "workType": "prd"
        }
      ],
      "type": "LOGICAL_MOVE",
      "worker": ""
    }
  ]
}
