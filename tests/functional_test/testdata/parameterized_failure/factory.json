{
  "name": "parameterized_failure",
  "workTypes": [
    {
      "name": "task",
      "states": [
        {
          "name": "init",
          "type": "INITIAL"
        },
        {
          "name": "complete",
          "type": "TERMINAL"
        },
        {
          "name": "failed",
          "type": "FAILED"
        }
      ]
    }
  ],
  "workers": [
    {
      "name": "exec-worker"
    }
  ],
  "workstations": [
    {
      "inputs": [
        {
          "state": "init",
          "workType": "task"
        }
      ],
      "name": "process",
      "onFailure": {
        "state": "failed",
        "workType": "task"
      },
      "outputs": [
        {
          "state": "complete",
          "workType": "task"
        }
      ],
      "worker": "exec-worker",
      "workingDirectory": "{{ .NonExistentField }}"
    }
  ]
}

