{
  "workTypes": [
    {
      "name": "prd",
      "states": [
        {
          "name": "init",
          "type": "INITIAL"
        },
        {
          "name": "in-review",
          "type": "PROCESSING"
        },
        {
          "name": "archived",
          "type": "TERMINAL"
        },
        {
          "name": "failed",
          "type": "FAILED"
        }
      ]
    }
  ],
  "workers": [
    {
      "name": "executor"
    },
    {
      "name": "reviewer"
    }
  ],
  "workstations": [
    {
      "inputs": [
        {
          "state": "init",
          "workType": "prd"
        }
      ],
      "name": "execute",
      "onFailure": {
        "state": "failed",
        "workType": "prd"
      },
      "outputs": [
        {
          "state": "in-review",
          "workType": "prd"
        }
      ],
      "worker": "executor"
    },
    {
      "inputs": [
        {
          "state": "in-review",
          "workType": "prd"
        }
      ],
      "name": "review",
      "onFailure": {
        "state": "failed",
        "workType": "prd"
      },
      "outputs": [
        {
          "state": "archived",
          "workType": "prd"
        }
      ],
      "worker": "reviewer"
    }
  ]
}
