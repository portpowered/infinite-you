{
  "name": "logical_move_pipeline_dir",
  "workTypes": [
    {
      "name": "task",
      "states": [
        {
          "name": "init",
          "type": "INITIAL"
        },
        {
          "name": "staging",
          "type": "PROCESSING"
        },
        {
          "name": "done",
          "type": "TERMINAL"
        },
        {
          "name": "failed",
          "type": "FAILED"
        }
      ]
    }
  ],
  "workers": [
    {
      "name": "logical-router"
    },
    {
      "name": "model-worker"
    }
  ],
  "workstations": [
    {
      "inputs": [
        {
          "state": "init",
          "workType": "task"
        }
      ],
      "name": "router",
      "outputs": [
        {
          "state": "staging",
          "workType": "task"
        }
      ],
      "worker": "logical-router"
    },
    {
      "inputs": [
        {
          "state": "staging",
          "workType": "task"
        }
      ],
      "name": "process",
      "onFailure": {
        "state": "failed",
        "workType": "task"
      },
      "outputs": [
        {
          "state": "done",
          "workType": "task"
        }
      ],
      "worker": "model-worker"
    }
  ]
}

