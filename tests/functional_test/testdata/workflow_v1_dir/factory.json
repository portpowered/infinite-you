{
  "workTypes": [
    {
      "name": "task",
      "states": [
        {
          "name": "init",
          "type": "INITIAL"
        },
        {
          "name": "processing",
          "type": "PROCESSING"
        },
        {
          "name": "complete",
          "type": "TERMINAL"
        },
        {
          "name": "failed",
          "type": "FAILED"
        }
      ]
    }
  ],
  "workers": [
    {
      "name": "processor"
    },
    {
      "name": "finalizer"
    }
  ],
  "workstations": [
    {
      "inputs": [
        {
          "state": "init",
          "workType": "task"
        }
      ],
      "name": "process",
      "onFailure": {
        "state": "failed",
        "workType": "task"
      },
      "outputs": [
        {
          "state": "processing",
          "workType": "task"
        }
      ],
      "worker": "processor"
    },
    {
      "inputs": [
        {
          "state": "processing",
          "workType": "task"
        }
      ],
      "name": "finalize",
      "onFailure": {
        "state": "failed",
        "workType": "task"
      },
      "outputs": [
        {
          "state": "complete",
          "workType": "task"
        }
      ],
      "worker": "finalizer"
    }
  ]
}
