{
  "name": "code_review",
  "workTypes": [
    {
      "name": "code-change",
      "states": [
        {
          "name": "init",
          "type": "INITIAL"
        },
        {
          "name": "in-review",
          "type": "PROCESSING"
        },
        {
          "name": "complete",
          "type": "TERMINAL"
        },
        {
          "name": "failed",
          "type": "FAILED"
        }
      ]
    }
  ],
  "workers": [
    {
      "name": "swe"
    },
    {
      "name": "reviewer"
    }
  ],
  "workstations": [
    {
      "inputs": [
        {
          "state": "init",
          "workType": "code-change"
        }
      ],
      "name": "coding",
      "onFailure": {
        "state": "failed",
        "workType": "code-change"
      },
      "outputs": [
        {
          "state": "in-review",
          "workType": "code-change"
        }
      ],
      "worker": "swe"
    },
    {
      "inputs": [
        {
          "state": "in-review",
          "workType": "code-change"
        }
      ],
      "name": "review",
      "onFailure": {
        "state": "failed",
        "workType": "code-change"
      },
      "onRejection": {
        "state": "init",
        "workType": "code-change"
      },
      "outputs": [
        {
          "state": "complete",
          "workType": "code-change"
        }
      ],
      "worker": "reviewer"
    }
  ]
}

