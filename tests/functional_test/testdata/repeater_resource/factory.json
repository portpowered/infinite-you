{
  "name": "repeater_resource",
  "resources": [
    {
      "capacity": 1,
      "name": "slot"
    }
  ],
  "workTypes": [
    {
      "name": "task",
      "states": [
        {
          "name": "init",
          "type": "INITIAL"
        },
        {
          "name": "processing",
          "type": "PROCESSING"
        },
        {
          "name": "complete",
          "type": "TERMINAL"
        },
        {
          "name": "failed",
          "type": "FAILED"
        }
      ]
    }
  ],
  "workers": [
    {
      "name": "exec-worker"
    },
    {
      "name": "finish-worker"
    }
  ],
  "workstations": [
    {
      "inputs": [
        {
          "state": "init",
          "workType": "task"
        }
      ],
      "behavior": "REPEATER",
      "name": "executor",
      "onFailure": {
        "state": "failed",
        "workType": "task"
      },
      "onRejection": {
        "state": "init",
        "workType": "task"
      },
      "outputs": [
        {
          "state": "processing",
          "workType": "task"
        }
      ],
      "resources": [
        {
          "capacity": 1,
          "name": "slot"
        }
      ],
      "worker": "exec-worker"
    },
    {
      "inputs": [
        {
          "state": "processing",
          "workType": "task"
        }
      ],
      "name": "finisher",
      "onFailure": {
        "state": "failed",
        "workType": "task"
      },
      "outputs": [
        {
          "state": "complete",
          "workType": "task"
        }
      ],
      "worker": "finish-worker"
    },
    {
      "guards": [
        {
          "maxVisits": 5,
          "type": "VISIT_COUNT",
          "workstation": "executor"
        }
      ],
      "inputs": [
        {
          "state": "init",
          "workType": "task"
        }
      ],
      "name": "executor-loop-breaker",
      "outputs": [
        {
          "state": "failed",
          "workType": "task"
        }
      ],
      "type": "LOGICAL_MOVE",
      "worker": ""
    }
  ]
}

