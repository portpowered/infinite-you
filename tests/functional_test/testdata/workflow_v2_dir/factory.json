{
  "name": "workflow_v2_dir",
  "workTypes": [
    {
      "name": "task",
      "states": [
        {
          "name": "init",
          "type": "INITIAL"
        },
        {
          "name": "processing",
          "type": "PROCESSING"
        },
        {
          "name": "in-review",
          "type": "PROCESSING"
        },
        {
          "name": "complete",
          "type": "TERMINAL"
        },
        {
          "name": "failed",
          "type": "FAILED"
        }
      ]
    }
  ],
  "workers": [
    {
      "name": "processor"
    },
    {
      "name": "reviewer"
    },
    {
      "name": "finalizer"
    }
  ],
  "workstations": [
    {
      "inputs": [
        {
          "state": "init",
          "workType": "task"
        }
      ],
      "name": "process",
      "onFailure": {
        "state": "failed",
        "workType": "task"
      },
      "outputs": [
        {
          "state": "processing",
          "workType": "task"
        }
      ],
      "worker": "processor"
    },
    {
      "inputs": [
        {
          "state": "processing",
          "workType": "task"
        }
      ],
      "name": "review",
      "onFailure": {
        "state": "failed",
        "workType": "task"
      },
      "onRejection": {
        "state": "init",
        "workType": "task"
      },
      "outputs": [
        {
          "state": "in-review",
          "workType": "task"
        }
      ],
      "worker": "reviewer"
    },
    {
      "inputs": [
        {
          "state": "in-review",
          "workType": "task"
        }
      ],
      "name": "finalize",
      "onFailure": {
        "state": "failed",
        "workType": "task"
      },
      "outputs": [
        {
          "state": "complete",
          "workType": "task"
        }
      ],
      "worker": "finalizer"
    }
  ]
}

