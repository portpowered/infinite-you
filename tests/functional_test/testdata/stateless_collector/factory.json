{
  "name": "stateless_collector",
  "workTypes": [
    {
      "name": "task",
      "states": [
        {
          "name": "init",
          "type": "INITIAL"
        },
        {
          "name": "stage1",
          "type": "PROCESSING"
        },
        {
          "name": "done",
          "type": "TERMINAL"
        },
        {
          "name": "failed",
          "type": "FAILED"
        }
      ]
    }
  ],
  "workers": [
    {
      "name": "agent"
    }
  ],
  "workstations": [
    {
      "inputs": [
        {
          "state": "init",
          "workType": "task"
        }
      ],
      "name": "step1",
      "onFailure": {
        "state": "failed",
        "workType": "task"
      },
      "outputs": [
        {
          "state": "stage1",
          "workType": "task"
        }
      ],
      "worker": "agent"
    },
    {
      "inputs": [
        {
          "state": "stage1",
          "workType": "task"
        }
      ],
      "name": "step2",
      "onFailure": {
        "state": "failed",
        "workType": "task"
      },
      "outputs": [
        {
          "state": "done",
          "workType": "task"
        }
      ],
      "worker": "agent"
    }
  ]
}

