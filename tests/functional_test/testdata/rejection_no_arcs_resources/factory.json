{
  "name": "rejection_no_arcs_resources",
  "resources": [
    {
      "capacity": 1,
      "name": "slot"
    }
  ],
  "workTypes": [
    {
      "name": "task",
      "states": [
        {
          "name": "init",
          "type": "INITIAL"
        },
        {
          "name": "done",
          "type": "TERMINAL"
        },
        {
          "name": "failed",
          "type": "FAILED"
        }
      ]
    }
  ],
  "workers": [
    {
      "name": "worker"
    }
  ],
  "workstations": [
    {
      "inputs": [
        {
          "state": "init",
          "workType": "task"
        }
      ],
      "name": "process",
      "onFailure": {
        "state": "failed",
        "workType": "task"
      },
      "outputs": [
        {
          "state": "done",
          "workType": "task"
        }
      ],
      "resources": [
        {
          "capacity": 1,
          "name": "slot"
        }
      ],
      "worker": "worker"
    }
  ]
}

